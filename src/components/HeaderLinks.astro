---
import Default from '@astrojs/starlight/components/SocialIcons.astro';
---

<div class="header-links">
  <a
    href="https://github.com/WesTIChU/blogr.directory/issues/new/choose"
    target="_blank"
    rel="noopener noreferrer"
    class="report-ai-link"
  >
    ⚠️ Report AI
  </a>

  <span class="divider"></span>

  <Default><slot /></Default>
</div>

<style>
  .header-links {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .report-ai-link {
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--sl-color-text);
    opacity: 0.85;
  }

  .report-ai-link:hover {
    opacity: 1;
  }

  .divider {
    width: 1px;
    height: 18px;
    background: var(--sl-color-hairline);
    margin: 0 0.3rem;
  }
</style>