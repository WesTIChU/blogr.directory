---
import Default from '@astrojs/starlight/components/SocialIcons.astro';
import { getDirectoryLinks } from '../lib/getDirectoryLinks';

const links = getDirectoryLinks();
console.log('RANDOM BLOG LINKS:', links);
---

<div class="header-links">
  <a
    href="#"
    class="random-link"
    data-links={JSON.stringify(links)}
  >
    🎲 Random Link
  </a>

  <span class="divider"></span>

  <a
    href="https://github.com/WesTIChU/blogr.directory/issues/new/choose"
    target="_blank"
    rel="noopener noreferrer"
    class="report-ai-link"
  >
    ⚠️ Report AI
  </a>

  <span class="divider"></span>

  <Default><slot /></Default>
</div>

<script is:inline>
  const randomLinkEl = document.querySelector('.random-link');

  if (randomLinkEl) {
    const links = JSON.parse(randomLinkEl.getAttribute('data-links') || '[]');

    randomLinkEl.addEventListener('click', (event) => {
      event.preventDefault();

      if (!Array.isArray(links) || links.length === 0) return;

      const randomIndex = Math.floor(Math.random() * links.length);
      const randomUrl = links[randomIndex];

      window.open(randomUrl, '_blank', 'noopener,noreferrer');
    });
  }
</script>

<style>
  .header-links {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .report-ai-link,
  .random-link {
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--sl-color-text);
    opacity: 0.85;
  }

  .report-ai-link:hover,
  .random-link:hover {
    opacity: 1;
  }

  .divider {
    width: 1px;
    height: 18px;
    background: var(--sl-color-hairline);
    margin: 0 0.3rem;
  }
</style>